modules = ["nodejs-20", "web", "postgresql-16", "python-3.11"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["libuuid", "fontconfig", "freetype", "cairo", "pango", "giflib", "libjpeg", "librsvg"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[env]
PORT = "5000"

[deployment]
deploymentTarget = "cloudrun"
build = ["npm", "run", "build"]
run = ["node", "./dist/index.cjs"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[agent]
mockupState = "FULLSTACK"
integrations = ["hubspot:1.0.0", "github:1.0.0"]

[userenv]

[userenv.shared]
VITE_RECAPTCHA_SITE_KEY = "6Lcell4sAAAAAFA3SCozHZMm34rouyzu2IMstGEc"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
